{
  "name": "@leadertechie/md2compose",
  "version": "0.1.0-alpha.2",
  "description": "Generic markdown composition engine - stitch, slot, and hydrate markdown content with parent/child inheritance",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run"
  },
  "dependencies": {
    "@leadertechie/r2tohtml": "^0.1.0-alpha.14"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "markdown",
    "compose",
    "stitch",
    "slot",
    "template",
    "content"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leadertechie/md2compose.git"
  }
